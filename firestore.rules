// Rules for the MAIN Firebase project (PUBLIC_FIREBASE_PROJECT_ID).
// Apply in Firebase console → Firestore Database → Rules, or with
// `firebase deploy --only firestore:rules` if you set up firebase.json.
//
// Model: the site reads projects/blogs/community anonymously. Writing a
// community comment requires a silent anonymous Firebase Auth session (no
// login UI — see ensureAnonAuth in src/lib/firebase.ts) so a chosen display
// name can be bound to a "names" claim and impersonating someone else's name
// is rejected. Admin edits and deletes go through /api/admin/* with a
// service account, which bypasses these rules.
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /projects/{id} {
      allow read: if true;
      allow write: if false;
    }

    match /blogs/{id} {
      allow read: if true;
      allow write: if false;
    }

    match /community/{id} {
      allow read: if true;
      // The form caps name at 40 and message at 280; the slack here only
      // covers older clients, not abuse. The name field is required — "traveler"
      // is a reserved shared handle (anyone can post as it, unclaimed) for any
      // client that still sends it; everyone else must own their name via a
      // names/{name} claim below. "goblin" is reserved for admin replies
      // (written by the service account, which bypasses these rules) and can
      // never be claimed — see the names/{nameId} rule.
      allow create: if request.auth != null
        && request.resource.data.keys().hasOnly(['name', 'message', 'timestamp', 'parentId'])
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 60
        && request.resource.data.message is string
        && request.resource.data.message.size() > 0
        && request.resource.data.message.size() <= 600
        && request.resource.data.timestamp is string
        && request.resource.data.timestamp.size() <= 40
        && (!('parentId' in request.resource.data)
          || (request.resource.data.parentId is string
            && request.resource.data.parentId.size() <= 128))
        && (request.resource.data.name.lower() == 'traveler'
          || get(/databases/$(database)/documents/names/$(request.resource.data.name.lower())).data.owner == request.auth.uid);
      allow update, delete: if false;
    }

    match /names/{nameId} {
      allow read: if true;
      // Claiming a name is a one-time create keyed by its lowercased text.
      // No update/delete means nobody can steal or release someone else's
      // claim — whichever anonymous uid claims a name keeps it for good.
      allow create: if request.auth != null
        && nameId == nameId.lower()
        && nameId != 'traveler'
        && nameId != 'goblin'
        && request.resource.data.keys().hasOnly(['owner', 'createdAt'])
        && request.resource.data.owner == request.auth.uid
        && request.resource.data.createdAt is string;
      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
