---
import "../styles/global.css";
import "../styles/info.css";

const updated = "2026-07-18";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>Terms of Use — Goblin Town</title>
    <meta
      name="description"
      content="Terms of use for Goblin Town (g0.monster) — a personal portfolio site by Vishal Gurung."
    />
    <meta name="robots" content="index,follow" />
    <link rel="canonical" href="https://g0.monster/terms/" />
    <meta property="og:site_name" content="Goblin Town" />
    <meta property="og:title" content="Terms of Use — Goblin Town" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://g0.monster/terms/" />
    <meta property="og:image" content="https://g0.monster/og/goblin-town-og.png" />
    <meta name="theme-color" content="#0c0610" />
    <link rel="icon" href="/favicon.png" type="image/png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700;800&display=swap"
    />
  </head>
  <body class="info-body">
    <div class="info-wrapper">
    <div class="info-page info-legal info-inner">
      <nav class="info-legal-nav">
        <a href="/info/">← Summary</a>
        <a href="/">Enter Game</a>
      </nav>

      <article class="info-main">
        <h2 class="info-title">Terms of Use</h2>
        <p class="small">Last updated {updated}</p>

        <p class="info-lead">
          Goblin Town is the personal portfolio of <strong>Vishal Gurung</strong>. It's a small
          town — be a good visitor and these terms stay short.
        </p>

        <h3>The site</h3>
        <p>
          Everything here is provided as-is, for free, with no warranty of any kind. The town may
          change, break, or go dark for maintenance at any time.
        </p>

        <h3>Content &amp; ownership</h3>
        <p>
          The site's original content — code, writing, and design — belongs to Vishal Gurung
          unless noted otherwise. Some pixel-art assets are third-party asset packs used under
          their own licenses and remain the property of their creators.
        </p>

        <h3>Your posts &amp; doodles</h3>
        <ul class="info-list">
          <li>What you draw or write stays yours — posting just lets this site display it.</li>
          <li>Keep it friendly: no unlawful, hateful, or explicit content, and no spam.</li>
          <li>Anything can be removed at any time, without notice, at the goblin's discretion.</li>
        </ul>

        <h3>Liability</h3>
        <p>
          To the extent the law allows, Vishal Gurung is not liable for any damages arising from
          use of this site or from content posted by visitors.
        </p>

        <h3>Contact</h3>
        <p>
          Questions or takedown requests:
          <a href="mailto:grgvishal.gurung17@gmail.com">grgvishal.gurung17@gmail.com</a>. See also
          the <a href="/privacy/">Privacy &amp; Cookie Policy</a>.
        </p>
      </article>

      <footer class="info-footer">
        <div class="info-footer-legal">
          <p class="small">© {new Date().getFullYear()} Vishal Gurung. All rights reserved.</p>
          <nav class="info-footer-links">
            <a href="/privacy/">Privacy &amp; Cookies</a>
            <span aria-hidden="true">·</span>
            <a href="/terms/">Terms</a>
            <span aria-hidden="true">·</span>
            <a href="mailto:grgvishal.gurung17@gmail.com">Contact</a>
          </nav>
        </div>
      </footer>
    </div>
    </div>
  </body>
</html>
