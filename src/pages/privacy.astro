---
import "../styles/global.css";
import "../styles/info.css";

const updated = "2026-07-18";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>Privacy &amp; Cookies — Goblin Town</title>
    <meta
      name="description"
      content="Privacy and cookie policy for Goblin Town (g0.monster). Short version: no cookies, no trackers, no analytics."
    />
    <meta name="robots" content="index,follow" />
    <link rel="canonical" href="https://g0.monster/privacy/" />
    <meta property="og:site_name" content="Goblin Town" />
    <meta property="og:title" content="Privacy & Cookies — Goblin Town" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://g0.monster/privacy/" />
    <meta property="og:image" content="https://g0.monster/og/goblin-town-og.png" />
    <meta name="theme-color" content="#0c0610" />
    <link rel="icon" href="/favicon.png" type="image/png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700;800&display=swap"
    />
  </head>
  <body class="info-body">
    <div class="info-wrapper">
      <div class="info-page info-legal info-inner">
        <nav class="info-legal-nav">
          <a href="/info/">← Summary</a>
          <a href="/">Enter Game</a>
        </nav>

        <article class="info-main">
          <h2 class="info-title">Privacy &amp; Cookie Policy</h2>
          <p class="small">Last updated {updated}</p>

          <p class="info-lead">
            Short version: this site sets <strong>no cookies</strong>, runs
            <strong>no analytics</strong>, and has <strong>no trackers</strong>. The only personal
            data it ever holds is what you choose to post on the wall.
          </p>

          <h3>Cookies</h3>
          <p>
            Goblin Town does not use cookies — not for tracking, not for ads, not for preferences.
            That is why there is no cookie consent banner: there is nothing to consent to.
          </p>

          <h3>What you submit</h3>
          <p>
            If you leave a doodle or a community message, that content — plus the optional name you
            type — is stored in Google Firebase (Firestore) and shown publicly on this site. Don't
            include anything private in a post; anyone can read it. Want something you posted taken
            down? Email
            <a href="mailto:grgvishal.gurung17@gmail.com">grgvishal.gurung17@gmail.com</a> and it will
            be removed.
          </p>

          <h3>Local browser storage</h3>
          <p>
            The Firebase library the site uses may keep technical data in your browser's local
            storage (IndexedDB) to do its job. This stays on your device, is not used to track you,
            and clearing your browser data removes it.
          </p>

          <h3>Third-party services</h3>
          <ul class="info-list">
            <li>
              <strong>Cloudflare</strong> hosts the site and may process your IP address to serve pages
              and protect against abuse.
            </li>
            <li>
              <strong>Google Firebase</strong> stores doodles and community messages.
            </li>
            <li>
              <strong>Google Fonts</strong> serves the site's fonts, so your browser requests them from
              Google's servers.
            </li>
          </ul>
          <p>Each of these processes data under its own privacy policy.</p>

          <h3>Questions</h3>
          <p>
            Email <a href="mailto:grgvishal.gurung17@gmail.com">grgvishal.gurung17@gmail.com</a> — the
            goblin reads everything.
          </p>
        </article>

        <footer class="info-footer">
          <div class="info-footer-legal">
            <p class="small">© {new Date().getFullYear()} Vishal Gurung. All rights reserved.</p>
            <nav class="info-footer-links">
              <a href="/privacy/">Privacy &amp; Cookies</a>
              <span aria-hidden="true">·</span>
              <a href="/terms/">Terms</a>
              <span aria-hidden="true">·</span>
              <a href="mailto:grgvishal.gurung17@gmail.com">Contact</a>
            </nav>
          </div>
        </footer>
      </div>
    </div>
  </body>
</html>
