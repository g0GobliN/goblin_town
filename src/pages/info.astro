---
import "../styles/global.css";
import "../styles/info.css";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>Goblin Town — Summary · Vishal Gurung</title>
    <meta
      name="description"
      content="Quick summary of Goblin Town — Vishal Gurung, work, notes, doodles, and how to say hello. Prefer reading over playing? Start here."
    />
    <meta name="author" content="Vishal Gurung" />
    <meta name="robots" content="index,follow,max-image-preview:large" />
    <link rel="canonical" href="https://g0.monster/info/" />
    <meta property="og:site_name" content="Goblin Town" />
    <meta property="og:title" content="Goblin Town — Summary" />
    <meta
      property="og:description"
      content="Text summary of Vishal Gurung's playable portfolio — work, notes, doodles, and contact."
    />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://g0.monster/info/" />
    <meta property="og:image" content="https://g0.monster/og/goblin-town-og.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta
      property="og:image:alt"
      content="Pixel-art night town with a grinning goblin — Goblin Town, a playable portfolio at g0.monster"
    />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content="https://g0.monster/og/goblin-town-og.png" />
    <meta name="theme-color" content="#0c0610" />
    <link rel="icon" href="/favicon.png" type="image/png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=New+Rocker&family=Press+Start+2P&family=VT323&display=swap"
    />
    <script is:inline type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "ProfilePage",
        "url": "https://g0.monster/info/",
        "name": "Goblin Town — Summary",
        "mainEntity": {
          "@type": "Person",
          "name": "Vishal Gurung",
          "url": "https://g0.monster/",
          "email": "grgvishal.gurung17@gmail.com",
          "jobTitle": "IT Engineer",
          "workLocation": {
            "@type": "Place",
            "address": {
              "@type": "PostalAddress",
              "addressLocality": "Tokyo",
              "addressCountry": "JP"
            }
          },
          "knowsAbout": [
            "Web development",
            "WebRTC",
            "System development",
            "Cameras",
            "Game development"
          ],
          "sameAs": ["https://github.com/g0GobliN", "https://instagram.com/goblin01_"]
        }
      }
    </script>
  </head>
  <body class="info-body">
    <div class="info-stage" aria-hidden="true">
      <img class="info-stage-bg" src="/img/gothicvania/town/background.png" alt="" />
      <img class="info-stage-mid" src="/img/gothicvania/town/middleground.png" alt="" />
      <div class="info-stage-veil"></div>
    </div>

    <div class="info-page">
      <header class="info-hero">
        <p class="info-kicker">PORTFOLIO TOWN</p>
        <h1 class="info-logo">
          <span>GOBLIN</span>
          <span class="info-logo-sub">TOWN</span>
        </h1>
        <p class="info-hero-sub">Vishal Gurung — engineer in Tokyo, builder by night.</p>
        <div class="info-hero-cast" aria-hidden="true">
          <img
            src="/img/gothicvania/player/goblin/idle1.png"
            alt=""
            class="info-sprite info-sprite-goblin"
          />
          <img src="/img/gothicvania/town/hat-man-idle.png" alt="" class="info-sprite" />
          <img src="/img/gothicvania/cemetery/skeleton/skeleton-1.png" alt="" class="info-sprite" />
          <img
            src="/img/gothicvania/cemetery/hell-gato/hell-gato-1.png"
            alt=""
            class="info-sprite"
          />
        </div>
        <ul class="info-tags">
          <li>PLAYABLE</li>
          <li>PIXEL</li>
          <li>TOKYO</li>
          <li>ENGINEER</li>
          <li>OPEN SOURCE</li>
        </ul>
      </header>

      <div class="info-cta-bar">
        <a class="info-cta" href="/">Enter Game</a>
        <p class="info-cta-note">Walk the streets — or keep reading below.</p>
      </div>

      <div class="info-layout">
        <article class="info-main">
          <h2 class="info-title">Goblin Town — Vishal Gurung</h2>
          <p class="info-lead">
            This is my portfolio — a small pixel town you can play right in the browser. The houses
            hold my work and notes, the gallery wall shows visitor doodles, and the church gate is
            where you can say hello.
          </p>

          <p>
            Hey — I'm <strong>Vishal Gurung</strong>, online just <strong>goblin</strong>. I grew up
            in Nepal, live in Tokyo, and work as an IT engineer (システムエンジニア). Outside work I
            build side projects — apps, tools, open source, and fun experiments like this town.
          </p>

          <h3>Contents</h3>
          <ul class="info-list">
            <li><strong>House Diary</strong> — who lives here</li>
            <li><strong>Workshop</strong> — selected builds &amp; projects</li>
            <li><strong>Library</strong> — notes &amp; posts</li>
            <li><strong>Gallery Wall</strong> — visitor doodles</li>
            <li><strong>Sketch Alley</strong> — leave your own mark</li>
            <li><strong>Church Gate</strong> — email, GitHub, hello</li>
          </ul>

          <h3>Controls (in town)</h3>
          <ul class="info-list">
            <li>
              Desktop — walk with A / D, run with Shift, jump with W, attack with J or X, talk &amp;
              heal with Space, menu with M.
            </li>
            <li>
              Phone — the left stick walks (hold RUN to sprint), then JUMP to jump, HIT to attack,
              ACT to talk.
            </li>
          </ul>

          <h3>Say hello</h3>
          <ul class="info-list info-links">
            <li>
              Email —
              <a href="mailto:grgvishal.gurung17@gmail.com">grgvishal.gurung17@gmail.com</a>
            </li>
            <li>
              GitHub —
              <a href="https://github.com/g0GobliN" target="_blank" rel="noopener">g0GobliN</a>
            </li>
            <li>
              Instagram —
              <a href="https://instagram.com/goblin01_" target="_blank" rel="noopener">goblin01_</a>
            </li>
            <li>
              RealityMap —
              <a href="https://www.npmjs.com/package/reality-map" target="_blank" rel="noopener"
                >npm package</a
              >
            </li>
          </ul>
        </article>

        <aside class="info-side">
          <figure class="info-shot">
            <img src="/img/gothicvania/town/house-a.png" alt="Workshop house" />
            <figcaption>The workshop — builds live here</figcaption>
          </figure>
          <figure class="info-shot">
            <img src="/img/gothicvania/town/house-b.png" alt="Library house" />
            <figcaption>The library — notes &amp; ink</figcaption>
          </figure>
          <figure class="info-shot">
            <img src="/img/gothicvania/cemetery/graveyard.png" alt="Cemetery path" />
            <figcaption>Night roads — mind the ghosts</figcaption>
          </figure>
          <figure class="info-shot info-shot-row">
            <img src="/img/gothicvania/player/goblin/attack3.png" alt="Goblin attack" />
            <img src="/img/gothicvania/church/ghoul/burning-ghoul1.png" alt="Ghoul" />
            <img src="/img/gothicvania/cemetery/ghost/ghost-1.png" alt="Ghost" />
            <figcaption>The locals — mostly friendly</figcaption>
          </figure>
        </aside>
      </div>

      <section class="info-section">
        <div class="info-section-head">
          <h3>Workshop</h3>
          <p class="small" id="work-status">&gt; unlocking...</p>
        </div>
        <div id="work-list" class="info-cards"></div>
      </section>

      <section class="info-section">
        <div class="info-section-head">
          <h3>Library</h3>
          <p class="small" id="blog-status">&gt; lighting lamps...</p>
        </div>
        <div id="blog-list" class="info-cards"></div>
      </section>

      <section class="info-section">
        <div class="info-section-head">
          <h3>Gallery wall</h3>
          <p class="small" id="doodle-status">&gt; dusting...</p>
        </div>
        <div class="info-doodle-cta">
          <button id="doodle-open-btn" class="info-card-btn" type="button">
            WANT TO DOODLE? CLICK HERE
          </button>
          <p class="small">Draw something — it hangs on this wall for everyone to see.</p>
        </div>
        <div id="doodle-pad" class="info-doodle-pad" hidden>
          <div class="info-doodle-modal" role="dialog" aria-label="Doodle pad">
            <p class="small accent info-doodle-kicker">SKETCH ALLEY · leave a mark</p>
            <canvas id="info-doodle-canvas" width="360" height="240"></canvas>
            <div class="info-doodle-tools">
              <div id="info-doodle-palette" class="info-doodle-palette">
                <button
                  id="info-doodle-eraser"
                  class="doodle-swatch doodle-eraser-swatch"
                  type="button"
                  aria-label="Eraser"
                  title="Eraser"></button>
              </div>
              <div class="info-doodle-size" role="group" aria-label="Brush size">
                <span class="small">size</span>
                <div id="info-doodle-sizes" class="doodle-size-presets">
                  <button type="button" class="doodle-size-btn" data-size="2" aria-label="Thin">
                    <span class="doodle-size-dot"></span>
                  </button>
                  <button
                    type="button"
                    class="doodle-size-btn is-active"
                    data-size="4"
                    aria-label="Medium"
                  >
                    <span class="doodle-size-dot"></span>
                  </button>
                  <button type="button" class="doodle-size-btn" data-size="7" aria-label="Thick">
                    <span class="doodle-size-dot"></span>
                  </button>
                  <button type="button" class="doodle-size-btn" data-size="10" aria-label="Bold">
                    <span class="doodle-size-dot"></span>
                  </button>
                </div>
              </div>
            </div>
            <input
              id="info-doodle-name"
              type="text"
              maxlength="40"
              placeholder="name (optional)"
              autocomplete="nickname"
            />
            <div class="info-doodle-actions">
              <button id="info-doodle-save" class="info-card-btn" type="button">
                HANG IT ON THE WALL
              </button>
              <button id="info-doodle-clear" class="info-reply-btn" type="button">CLEAR</button>
              <button id="info-doodle-cancel" class="info-reply-btn" type="button">CANCEL</button>
            </div>
            <p class="small" id="info-doodle-save-status"></p>
          </div>
        </div>
        <div id="doodle-grid" class="info-doodles"></div>
      </section>

      <section class="info-section">
        <div class="info-section-head">
          <h3>Community</h3>
          <p class="small" id="community-status">&gt; ringing the town bell...</p>
        </div>
        <form id="community-form" class="info-community-form">
          <input
            id="community-name"
            type="text"
            maxlength="40"
            placeholder="name (optional)"
            autocomplete="nickname"
          />
          <textarea
            id="community-message"
            maxlength="280"
            required
            placeholder="leave a message for the town..."></textarea>
          <button class="info-card-btn info-community-btn" type="submit">POST MESSAGE</button>
        </form>
        <div id="community-list" class="info-community"></div>
      </section>

      <footer class="info-footer">
        <a class="info-cta info-cta-footer" href="/">Enter Game</a>
        <p class="small">Prefer the streets? The game is the real portfolio.</p>
      </footer>
    </div>

    <script>
      import {
        getCommunityPosts,
        getDbBlogs,
        getDbProjects,
        getDoodles,
        saveCommunityPost,
        saveDoodle,
      } from "../lib/firebase";

      function escapeHtml(value: string) {
        return value
          .replaceAll("&", "&amp;")
          .replaceAll("<", "&lt;")
          .replaceAll(">", "&gt;")
          .replaceAll('"', "&quot;");
      }

      function escapeAttr(value: string) {
        return escapeHtml(value).replaceAll("'", "&#39;");
      }

      async function loadWork() {
        const list = document.getElementById("work-list")!;
        const status = document.getElementById("work-status")!;
        const projects = await getDbProjects();
        if (!projects.length) {
          status.textContent = "> forge is cold for now";
          list.innerHTML = `<article class="info-card"><div><strong>RealityMap</strong><p class="small">Already on npm — more builds land here soon.</p></div><a class="info-card-btn" href="https://www.npmjs.com/package/reality-map" target="_blank" rel="noopener">View</a></article>`;
          return;
        }
        status.textContent = `> ${projects.length} project${projects.length === 1 ? "" : "s"}`;
        list.innerHTML = projects
          .slice(0, 8)
          .map((p) => {
            const href = `/work/${encodeURIComponent(p.slug)}`;
            return `<a class="info-card info-card-link" href="${escapeAttr(href)}">
              <div>
                <strong>${escapeHtml(p.name || p.slug)}</strong>
                <p class="small">${escapeHtml(p.tagline || p.summary || "")}</p>
                <p class="small">${escapeHtml([p.year, p.role].filter(Boolean).join(" · "))}</p>
              </div>
              <span class="info-card-btn">Read</span>
            </a>`;
          })
          .join("");
      }

      async function loadBlog() {
        const list = document.getElementById("blog-list")!;
        const status = document.getElementById("blog-status")!;
        const blogs = await getDbBlogs();
        if (!blogs.length) {
          status.textContent = "> shelves waiting for ink";
          list.innerHTML = `<article class="info-card"><div><strong>No pages yet</strong><p class="small">Notes show up here when they're ready.</p></div><a class="info-card-btn" href="/">Town</a></article>`;
          return;
        }
        status.textContent = `> ${blogs.length} post${blogs.length === 1 ? "" : "s"}`;
        list.innerHTML = blogs
          .slice(0, 8)
          .map(
            (b) => `<a class="info-card info-card-link" href="/blog/${encodeURIComponent(b.slug)}">
              <div>
                <strong>${escapeHtml(b.title)}</strong>
                <p class="small">${escapeHtml(b.tagline || "")}</p>
                <p class="small">${escapeHtml(b.publishedAt || "")}</p>
              </div>
              <span class="info-card-btn">Read</span>
            </a>`,
          )
          .join("");
      }

      async function loadDoodles() {
        const grid = document.getElementById("doodle-grid")!;
        const status = document.getElementById("doodle-status")!;
        const doodles = await getDoodles();
        if (!doodles.length) {
          status.textContent = "> blank wall for now";
          grid.innerHTML = `<p class="small">Blank wall — hit “WANT TO DOODLE?” above and leave the first mark.</p>`;
          return;
        }
        status.textContent = `> ${doodles.length} doodle${doodles.length === 1 ? "" : "s"}`;
        grid.innerHTML = doodles
          .slice(0, 24)
          .map((d) => {
            const title = escapeHtml(d.name || "untitled");
            // Don't HTML-escape data URLs — only quote-break characters.
            const src = (d.doodle || "").replaceAll('"', "%22");
            const img = src
              ? `<img src="${src}" alt="${title}" loading="lazy" />`
              : `<div class="info-doodle-empty"></div>`;
            return `<figure class="info-doodle">${img}<figcaption class="small">${title}</figcaption></figure>`;
          })
          .join("");
      }

      function initInfoDoodlePad() {
        const openBtn = document.getElementById("doodle-open-btn") as HTMLButtonElement | null;
        const pad = document.getElementById("doodle-pad");
        const canvas = document.getElementById("info-doodle-canvas") as HTMLCanvasElement | null;
        if (!openBtn || !pad || !canvas) return;

        const ctx = canvas.getContext("2d")!;
        const paletteEl = document.getElementById("info-doodle-palette")!;
        const sizeBtns = [
          ...document.querySelectorAll<HTMLButtonElement>("#info-doodle-sizes .doodle-size-btn"),
        ];
        const eraserEl = document.getElementById("info-doodle-eraser");
        const nameEl = document.getElementById("info-doodle-name") as HTMLInputElement;
        const saveEl = document.getElementById("info-doodle-save") as HTMLButtonElement;
        const clearEl = document.getElementById("info-doodle-clear")!;
        const cancelEl = document.getElementById("info-doodle-cancel")!;
        const statusEl = document.getElementById("info-doodle-save-status")!;

        const PALETTE = ["#000000", "#ff6b6b", "#4d96ff", "#6bcb77", "#c56cf0", "#ffd93d"];
        const CANVAS_BG = "#f4e4bc";
        let color = PALETTE[0]!;
        let brushSize =
          Number(sizeBtns.find((b) => b.classList.contains("is-active"))?.dataset.size) || 4;
        let erasing = false;
        let drawing = false;
        let hasDrawn = false;
        let lastPoint: { x: number; y: number } | null = null;

        for (const btn of sizeBtns) {
          btn.addEventListener("click", () => {
            brushSize = Number(btn.dataset.size) || brushSize;
            for (const other of sizeBtns) other.classList.toggle("is-active", other === btn);
          });
        }

        const resetCanvas = () => {
          ctx.fillStyle = CANVAS_BG;
          ctx.fillRect(0, 0, canvas.width, canvas.height);
          hasDrawn = false;
        };
        resetCanvas();

        const swatches: HTMLButtonElement[] = [];
        const setErasing = (on: boolean) => {
          erasing = on;
          eraserEl?.classList.toggle("is-active", on);
          if (on) {
            for (const swatch of swatches) swatch.classList.remove("active");
          }
        };

        for (const swatchColor of PALETTE) {
          const button = document.createElement("button");
          button.className = "doodle-swatch";
          button.type = "button";
          button.style.background = swatchColor;
          button.setAttribute("aria-label", `pen color ${swatchColor}`);
          button.addEventListener("click", () => {
            color = swatchColor;
            setErasing(false);
            for (const swatch of swatches) swatch.classList.toggle("active", swatch === button);
          });
          paletteEl.appendChild(button);
          swatches.push(button);
        }
        swatches[0]!.classList.add("active");
        if (eraserEl) paletteEl.appendChild(eraserEl);

        eraserEl?.addEventListener("click", () => {
          setErasing(!erasing);
        });

        const pointerPos = (event: PointerEvent) => {
          const rect = canvas.getBoundingClientRect();
          return {
            x: ((event.clientX - rect.left) / rect.width) * canvas.width,
            y: ((event.clientY - rect.top) / rect.height) * canvas.height,
          };
        };

        canvas.addEventListener("pointerdown", (event) => {
          drawing = true;
          lastPoint = pointerPos(event);
          canvas.setPointerCapture(event.pointerId);
        });

        canvas.addEventListener("pointermove", (event) => {
          if (!drawing || !lastPoint) return;
          const point = pointerPos(event);
          ctx.strokeStyle = erasing ? CANVAS_BG : color;
          ctx.lineWidth = brushSize;
          ctx.lineCap = "round";
          ctx.beginPath();
          ctx.moveTo(lastPoint.x, lastPoint.y);
          ctx.lineTo(point.x, point.y);
          ctx.stroke();
          lastPoint = point;
          hasDrawn = true;
        });

        const endStroke = () => {
          drawing = false;
          lastPoint = null;
        };
        canvas.addEventListener("pointerup", endStroke);
        canvas.addEventListener("pointerleave", endStroke);

        const closePad = () => {
          pad.hidden = true;
        };

        openBtn.addEventListener("click", () => {
          pad.hidden = false;
          statusEl.textContent = "";
        });

        cancelEl.addEventListener("click", closePad);

        // click on the dark blurred backdrop (not the panel) closes the pad
        pad.addEventListener("click", (event) => {
          if (event.target === pad) closePad();
        });

        document.addEventListener("keydown", (event) => {
          if (event.key === "Escape" && !pad.hidden) closePad();
        });

        clearEl.addEventListener("click", resetCanvas);

        saveEl.addEventListener("click", async () => {
          if (!hasDrawn) {
            statusEl.textContent = "> draw something first!";
            return;
          }
          statusEl.textContent = "> hanging it up...";
          saveEl.disabled = true;
          try {
            await saveDoodle({
              name: nameEl.value.trim() || "goblin-sketch",
              text: "",
              doodle: canvas.toDataURL("image/png"),
              timestamp: new Date().toISOString(),
              createInDarkMode: false,
            });
            statusEl.textContent = "> it's on the wall!";
            closePad();
            resetCanvas();
            nameEl.value = "";
            await loadDoodles();
          } catch {
            statusEl.textContent = "> couldn't save — try again in a moment";
          } finally {
            saveEl.disabled = false;
          }
        });
      }

      import type { CommunityPost } from "../lib/firebase";

      function commentHtml(post: CommunityPost, byParent: Map<string, CommunityPost[]>): string {
        const when = (post.timestamp || "").slice(0, 10);
        const kids = byParent.get(post.id) || [];
        return `<article class="info-comment">
          <header>
            <strong>${escapeHtml(post.name || "traveler")}</strong>
            <span class="small">${escapeHtml(when)}</span>
          </header>
          <p>${escapeHtml(post.message || "")}</p>
          <button type="button" class="info-reply-btn" data-reply="${escapeAttr(post.id)}">↳ REPLY</button>
          ${kids.length ? `<div class="info-replies">${kids.map((k) => commentHtml(k, byParent)).join("")}</div>` : ""}
        </article>`;
      }

      async function loadCommunity() {
        const list = document.getElementById("community-list")!;
        const status = document.getElementById("community-status")!;
        const posts = await getCommunityPosts();
        if (!posts.length) {
          status.textContent = "> quiet square — leave the first message";
          list.innerHTML = "";
          return;
        }

        const byParent = new Map<string, CommunityPost[]>();
        const roots: CommunityPost[] = [];
        const ids = new Set(posts.map((p) => p.id));
        for (const post of posts) {
          if (post.parentId && ids.has(post.parentId)) {
            const siblings = byParent.get(post.parentId) || [];
            siblings.push(post);
            byParent.set(post.parentId, siblings);
          } else {
            roots.push(post);
          }
        }
        // roots newest first (already sorted desc); replies oldest first, reddit-style
        for (const kids of byParent.values()) {
          kids.sort((a, b) => String(a.timestamp || "").localeCompare(String(b.timestamp || "")));
        }

        status.textContent = `> ${posts.length} message${posts.length === 1 ? "" : "s"}`;
        list.innerHTML = roots
          .slice(0, 30)
          .map((p) => commentHtml(p, byParent))
          .join("");
        attachReplyHandlers(list, status);
      }

      async function submitPost(
        data: { name: string; message: string; parentId?: string },
        status: HTMLElement,
      ) {
        status.textContent = "> posting...";
        await saveCommunityPost({
          name: data.name || "traveler",
          message: data.message,
          timestamp: new Date().toISOString(),
          parentId: data.parentId,
        });
        await loadCommunity();
      }

      function attachReplyHandlers(list: HTMLElement, status: HTMLElement) {
        list.querySelectorAll<HTMLButtonElement>("[data-reply]").forEach((btn) => {
          btn.addEventListener("click", () => {
            const parentId = btn.dataset.reply!;
            const existing = list.querySelector<HTMLFormElement>(".info-reply-form");
            const wasOpenHere = existing?.dataset.parent === parentId;
            existing?.remove();
            if (wasOpenHere) return;

            const form = document.createElement("form");
            form.className = "info-community-form info-reply-form";
            form.dataset.parent = parentId;
            form.innerHTML = `
              <input type="text" maxlength="40" placeholder="name (optional)" autocomplete="nickname" />
              <textarea maxlength="280" required placeholder="write a reply..."></textarea>
              <button class="info-card-btn info-community-btn" type="submit">POST REPLY</button>`;
            btn.insertAdjacentElement("afterend", form);

            form.addEventListener("submit", async (event) => {
              event.preventDefault();
              const nameEl = form.querySelector("input")!;
              const messageEl = form.querySelector("textarea")!;
              const submitBtn = form.querySelector("button")!;
              const message = messageEl.value.trim();
              if (!message) return;
              submitBtn.disabled = true;
              try {
                await submitPost({ name: nameEl.value.trim(), message, parentId }, status);
              } catch (err) {
                console.error(err);
                status.textContent = "> couldn't post — try again in a moment";
                submitBtn.disabled = false;
              }
            });
            form.querySelector("textarea")!.focus();
          });
        });
      }

      const communityForm = document.getElementById("community-form") as HTMLFormElement | null;
      communityForm?.addEventListener("submit", async (event) => {
        event.preventDefault();
        const nameEl = document.getElementById("community-name") as HTMLInputElement;
        const messageEl = document.getElementById("community-message") as HTMLTextAreaElement;
        const status = document.getElementById("community-status")!;
        const button = communityForm.querySelector("button")!;
        const message = messageEl.value.trim();
        if (!message) return;

        button.disabled = true;
        try {
          await submitPost({ name: nameEl.value.trim(), message }, status);
          messageEl.value = "";
        } catch (err) {
          console.error(err);
          status.textContent = "> couldn't post — try again in a moment";
        } finally {
          button.disabled = false;
        }
      });

      initInfoDoodlePad();
      void Promise.all([loadWork(), loadBlog(), loadDoodles(), loadCommunity()]);
    </script>
  </body>
</html>
