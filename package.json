  "dependencies": {
    "@astrojs/cloudflare": "^14.1.3",
    "@astrojs/sitemap": "^3.7.3",
    "astro": "^7.1.1",
    "firebase": "^12.16.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "prettier": "^3.7.3",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^5.8.3",
    "wrangler": "^4.112.0"
  }
}
